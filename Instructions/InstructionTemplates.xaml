<ResourceDictionary
    x:Class="NINA.RtspTimelapse.Plugin.Instructions.InstructionTemplates"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:NINA.RtspTimelapse.Plugin.Instructions"
    xmlns:nina="clr-namespace:NINA.View.Sequencer;assembly=NINA.Sequencer">

    <!-- Icon referenced by [ExportMetadata("Icon", "RtspTimelapse_SVG")] on the instructions
         and by the dock panel. Simple camcorder glyph. -->
    <GeometryGroup x:Key="RtspTimelapse_SVG" FillRule="Nonzero">
        <PathGeometry Figures="M3,6 H15 V18 H3 Z M15,9.5 L21,6 V18 L15,14.5 Z" />
    </GeometryGroup>

    <!-- Start Timelapse Capture -->
    <DataTemplate DataType="{x:Type local:StartCapture}">
        <nina:SequenceBlockView DataContext="{Binding}">
            <nina:SequenceBlockView.SequenceItemContent>
                <CheckBox Content="Wait until capturing"
                          VerticalAlignment="Center"
                          IsChecked="{Binding WaitUntilCapturing}" />
            </nina:SequenceBlockView.SequenceItemContent>
        </nina:SequenceBlockView>
    </DataTemplate>

    <!-- Stop Timelapse Capture (no options) -->
    <DataTemplate DataType="{x:Type local:StopCapture}">
        <nina:SequenceBlockView DataContext="{Binding}" />
    </DataTemplate>

    <!-- Create Timelapse Video (renders the latest / started session; no options) -->
    <DataTemplate DataType="{x:Type local:CreateVideo}">
        <nina:SequenceBlockView DataContext="{Binding}" />
    </DataTemplate>

    <!-- Run Timelapse Capture (one block: start now; auto stop + optional video at sequence end) -->
    <DataTemplate DataType="{x:Type local:RunTimelapse}">
        <nina:SequenceBlockView DataContext="{Binding}">
            <nina:SequenceBlockView.SequenceItemContent>
                <StackPanel Orientation="Horizontal">
                    <CheckBox Content="Wait until capturing" VerticalAlignment="Center"
                              IsChecked="{Binding WaitUntilCapturing}" />
                    <CheckBox Content="Create video when finished" VerticalAlignment="Center"
                              Margin="12,0,0,0" IsChecked="{Binding CreateVideoWhenDone}" />
                </StackPanel>
            </nina:SequenceBlockView.SequenceItemContent>
        </nina:SequenceBlockView>
    </DataTemplate>
</ResourceDictionary>
