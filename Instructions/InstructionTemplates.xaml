<ResourceDictionary
    x:Class="NINA.RtspTimelapse.Plugin.Instructions.InstructionTemplates"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:NINA.RtspTimelapse.Plugin.Instructions"
    xmlns:nina="clr-namespace:NINA.View.Sequencer;assembly=NINA.Sequencer">

    <!-- Icon for the Start/Stop instructions and the dock panel. Simple camcorder glyph. -->
    <GeometryGroup x:Key="RtspTimelapse_SVG" FillRule="Nonzero">
        <PathGeometry Figures="M3,6 H15 V18 H3 Z M15,9.5 L21,6 V18 L15,14.5 Z" />
    </GeometryGroup>

    <!-- Start Timelapse Capture. NINA hides a CheckBox's Content, so label each toggle with a TextBlock. -->
    <DataTemplate DataType="{x:Type local:StartCapture}">
        <nina:SequenceBlockView DataContext="{Binding}">
            <nina:SequenceBlockView.SequenceItemContent>
                <StackPanel Orientation="Vertical">
                    <StackPanel Orientation="Horizontal" Margin="0,1"
                                ToolTip="Pause the sequence until the app captures the first frame (camera connected and streaming). Fails if no frame arrives within ~60s or capture stops. Turn off to continue as soon as the start command is accepted.">
                        <CheckBox IsChecked="{Binding WaitUntilCapturing}" VerticalAlignment="Center" />
                        <TextBlock Text="Wait for capture to start" VerticalAlignment="Center" Margin="6,0,0,0" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,1"
                                ToolTip="Stop capture if you stop/abort the sequence before a Stop block runs, so capture isn't left running. Note: with this on, stopping and resuming from the middle won't keep capture running.">
                        <CheckBox IsChecked="{Binding StopWhenSequenceStops}" VerticalAlignment="Center" />
                        <TextBlock Text="Stop capturing if the sequence is stopped" VerticalAlignment="Center" Margin="6,0,0,0" />
                    </StackPanel>
                </StackPanel>
            </nina:SequenceBlockView.SequenceItemContent>
        </nina:SequenceBlockView>
    </DataTemplate>

    <!-- Stop Timelapse Capture, with an optional render-after-stop. -->
    <DataTemplate DataType="{x:Type local:StopCapture}">
        <nina:SequenceBlockView DataContext="{Binding}">
            <nina:SequenceBlockView.SequenceItemContent>
                <StackPanel Orientation="Horizontal" Margin="0,1"
                            ToolTip="After stopping, render the timelapse video for this session (only its frames) and auto-upload to Discord if configured in the app.">
                    <CheckBox IsChecked="{Binding CreateVideoAfterStop}" VerticalAlignment="Center" />
                    <TextBlock Text="Create video when finished" VerticalAlignment="Center" Margin="6,0,0,0" />
                </StackPanel>
            </nina:SequenceBlockView.SequenceItemContent>
        </nina:SequenceBlockView>
    </DataTemplate>

    <!-- Scheduled Timelapse: capture until a chosen time (reuses NINA's time providers). -->
    <DataTemplate DataType="{x:Type local:ScheduledTimelapse}">
        <nina:SequenceBlockView DataContext="{Binding}">
            <nina:SequenceBlockView.SequenceItemContent>
                <StackPanel Orientation="Vertical">
                    <StackPanel Orientation="Horizontal" Margin="0,1">
                        <TextBlock Text="Until" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <ComboBox MinWidth="120" VerticalAlignment="Center" DisplayMemberPath="Name"
                                  ItemsSource="{Binding DateTimeProviders}"
                                  SelectedItem="{Binding SelectedProvider}" />
                        <TextBox MinWidth="28" Margin="8,0,0,0" VerticalAlignment="Center" TextAlignment="Right"
                                 IsEnabled="{Binding IsManualTime}"
                                 Text="{Binding Hours, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text=":" VerticalAlignment="Center" />
                        <TextBox MinWidth="28" VerticalAlignment="Center" TextAlignment="Right"
                                 IsEnabled="{Binding IsManualTime}"
                                 Text="{Binding Minutes, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text=":" VerticalAlignment="Center" />
                        <TextBox MinWidth="28" VerticalAlignment="Center" TextAlignment="Right"
                                 IsEnabled="{Binding IsManualTime}"
                                 Text="{Binding Seconds, UpdateSourceTrigger=PropertyChanged}" />
                        <StackPanel Orientation="Horizontal" Visibility="{Binding OffsetVisibility}">
                            <TextBlock Text="Offset" VerticalAlignment="Center" Margin="10,0,4,0" />
                            <TextBox MinWidth="34" VerticalAlignment="Center" TextAlignment="Right"
                                     Text="{Binding MinutesOffset, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="m" VerticalAlignment="Center" Margin="2,0,0,0" />
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,1">
                        <TextBlock Text="Day rollover" VerticalAlignment="Center" Margin="0,0,6,0" Opacity="0.7" />
                        <TextBlock VerticalAlignment="Center" Opacity="0.7"
                                   Text="{Binding RolloverTime, StringFormat={}{0:HH}:{0:mm}:{0:ss}}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,1"
                                ToolTip="When the target time is reached, render this session's timelapse video (uploads to Discord if configured in the app). Skipped if the sequence is stopped early.">
                        <CheckBox IsChecked="{Binding CreateVideoWhenDone}" VerticalAlignment="Center" />
                        <TextBlock Text="Create video when finished" VerticalAlignment="Center" Margin="6,0,0,0" />
                    </StackPanel>
                </StackPanel>
            </nina:SequenceBlockView.SequenceItemContent>
        </nina:SequenceBlockView>
    </DataTemplate>
</ResourceDictionary>
