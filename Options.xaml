<ResourceDictionary
    x:Class="NINA.RtspTimelapse.Plugin.Options"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Key must be "<AssemblyTitle>_Options" so N.I.N.A. shows it on the plugin's options page.
         DataContext is the RtspTimelapsePlugin instance. -->
    <DataTemplate x:Key="RTSP Timelapse Control_Options">
        <StackPanel Orientation="Vertical" Margin="0,5,0,0" TextElement.FontSize="14">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="Remote API port" VerticalAlignment="Center" Width="120" />
                <TextBox MinWidth="70" VerticalAlignment="Center"
                         Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" />
                <Button Content="Test connection" Margin="10,0,0,0" Padding="6,1"
                        FontSize="12" VerticalAlignment="Center"
                        Command="{Binding TestConnectionCommand}" />
                <TextBlock Text="{Binding TestResult}" Margin="10,0,0,0" FontSize="12"
                           VerticalAlignment="Center" Opacity="0.85" />
            </StackPanel>
            <!-- No MaxWidth: let it wrap to the available width instead of breaking mid-phrase. -->
            <TextBlock TextWrapping="Wrap" Opacity="0.7" FontSize="12"
                       Text="Must match the port in the RTSP Timelapse app (Integrations tab → Enable remote control API). The plugin connects to 127.0.0.1 on this PC only." />

            <!-- Prerequisites the user must configure in the RTSP Timelapse app. -->
            <TextBlock Text="Set up in the RTSP Timelapse app:" FontWeight="SemiBold" FontSize="12" Margin="0,12,0,3" />
            <StackPanel Orientation="Vertical" Margin="8,0,0,0" TextElement.FontSize="12">
                <TextBlock TextWrapping="Wrap" Opacity="0.85" Margin="0,1"
                           Text="• Integrations tab → enable the remote control API (use the same port as above)." />
                <TextBlock TextWrapping="Wrap" Opacity="0.85" Margin="0,1"
                           Text="• Capture tab → camera connection (IP, user, password, stream path) and capture interval." />
                <TextBlock TextWrapping="Wrap" Opacity="0.85" Margin="0,1"
                           Text="• Video Export tab → pick a preset and set the output location (where the timelapse videos are saved)." />
                <TextBlock TextWrapping="Wrap" Opacity="0.85" Margin="0,1"
                           Text="• Optional: Integrations tab → Discord webhook to auto-upload each finished video." />
            </StackPanel>

            <!-- Which block to use. -->
            <TextBlock Text="Suggested usage:" FontWeight="SemiBold" FontSize="12" Margin="0,12,0,3" />
            <StackPanel Orientation="Vertical" Margin="8,0,0,0" TextElement.FontSize="12">
                <TextBlock TextWrapping="Wrap" Opacity="0.85" Margin="0,1"
                           Text="• Start + Stop Timelapse Capture — capture alongside your imaging. Put Start where it begins and Stop where it ends; the defaults work as-is (Stop renders the video — 'Create video when finished' is on by default). Capture keeps running across a NINA pause/resume; the Stop block ends it." />
                <TextBlock TextWrapping="Wrap" Opacity="0.85" Margin="0,1"
                           Text="• Scheduled Timelapse — capture until a chosen time (e.g. Nautical Dawn), then auto-stop and render. No Stop block needed. Non-blocking: it hands the stop time to the app and the sequence continues immediately — the app stops and renders at that time even if the sequence has moved on or been stopped." />
            </StackPanel>

            <!-- About the app (this Plugins tab is the main way people discover it). -->
            <Separator Margin="0,12,0,8" Opacity="0.3" />
            <TextBlock TextWrapping="Wrap" FontSize="12"
                       Text="RTSP Timelapse Capture is a free, open-source Windows app that records timelapses from any RTSP / IP camera — with smart overnight / twilight scheduling, one-click MP4 export, and automatic Discord upload. This plugin lets N.I.N.A. start/stop capture and render the video as part of your sequence." />
            <TextBlock Margin="0,6,0,0" FontSize="12">
                <Hyperlink NavigateUri="https://github.com/HiranD/RTSP-Timelapse-Capture"
                           RequestNavigate="Hyperlink_RequestNavigate">Get the RTSP Timelapse Capture app →</Hyperlink>
            </TextBlock>
        </StackPanel>
    </DataTemplate>
</ResourceDictionary>
